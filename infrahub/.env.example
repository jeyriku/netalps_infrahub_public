# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — Infrahub Stack
#
# Copy this file to .env and adjust sensitive values before starting
# the stack with docker compose up -d.
# Never commit this file with passwords in production.
# ─────────────────────────────────────────────────────────────────────────────

# Infrahub version to deploy
INFRAHUB_VERSION=1.1.1

# Infrahub API/UI exposure port
INFRAHUB_PORT=8000

# API token for the admin account (used by Python scripts)
INFRAHUB_TOKEN=satoken

# Admin account password (web UI)
INFRAHUB_ADMIN_PASSWORD=infrahub

# Django secret key (change in production)
INFRAHUB_SECRET_KEY=netalps-demo-secret-key-changeme

# Mot de passe Neo4j
NEO4J_PASSWORD=infrahub

# Mot de passe RabbitMQ
RABBITMQ_PASSWORD=infrahub
